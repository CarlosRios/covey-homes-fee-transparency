# Entrata API credentials — copy to `.env` and fill in.
# `.env` is gitignored; never commit real keys.

# Base URL includes the client `{orgs}` path segment.
# Production (US): https://apis.entrata.com/ext/orgs/<orgs>/v1
ENTRATA_BASE_URL=https://apis.entrata.com/ext/orgs/<orgs>/v1

# API key issued via the Entrata Developer Portal subscription flow.
ENTRATA_API_KEY=

# Per-property IDs (one per community).
ENTRATA_PROPERTY_ID_TALLAHASSEE=
